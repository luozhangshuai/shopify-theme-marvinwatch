{%- liquid
  # 唯一 ID
  assign id = key
  # 将 data 赋值给一个变量
  assign data = data
  # 通过 data.group.value 获取到循环需要的数据
  assign group = data.group.value
  # 是否自动播放
  assign autoplay = autoplay | default: false
  # 图片比例（PC端）
  assign ratio_pc = data.ratio | default: 100
  # 图片比例（移动端）
  assign ratio_mobile = data.ratio_mobile | default: 133

  # 轮播每页显示数量（PC端）
  assign col_pc = data.col | default: 3
  assign gap_pc = data.gap | default: 10
  assign gap_pc_double = gap_pc | times: 2
  # 轮播每页显示数量（移动端）
  assign col_mobile = data.col_mobile | default: 3
  assign gap_mobile = data.gap_mobile | default: 10
  assign gap_mobile_double = gap_mobile | times: 2
  # 背景颜色
  assign bg = data.bg | default: '#d93636'
-%}

{%- unless group == blank -%}
  <style>
    #{{ id }} {
      --f-carousel-spacing: {{ gap_pc | append:'px' }};
      --f-carousel-slide-width: calc((100% - {{ gap_pc_double | append: 'px' }}) / {{ col_pc }});
    }
    @media screen and (max-width: 768px) {
      #{{ id }} {
        --f-carousel-spacing: {{ gap_mobile | append:'px' }};
        --f-carousel-slide-width: calc((100% - {{ gap_mobile_double | append: 'px' }}) / {{ col_mobile }});
      }
    }
  </style>

  <div x-data="fancyCarousel" class="{{ class }}" style="background: {{ bg }};">
    <!-- 用 script 标签包含数据 -->
    <script type="application/json" x-ref="datas">
      {
        "targetId": "{{ id }}",
        "options": {
          "Autoplay": false,
          "center": false,
          "transitionDuration": 30,
          "Dots": "false",
          "Navigation": true,
          "infinite": false,
          "transition": "crossfade"
        }
      }
    </script>

    <div class="f-carousel" id="{{ id }}">
      <div class="f-carousel__viewport">
        <div class="f-carousel__track items-baseline">
          {%- for item in group -%}
            <div class="f-carousel__slide w-full">
              <div class="relative" style="padding-top: {{ ratio_pc | append: '%' }}">
                <div class="absolute inset-0">
                  <div class="w-full h-full flex flex-col justify-center items-center gap-6 sm:gap-4 md:gap-4 tracking-normal bg-[#101010] text-white text-center text-sm sm:text-3xs md:text-3xs">
                    {%- liquid
                      # 海报
                      assign poster = item.poster.value
                      assign title = item.title | metafield_tag
                      assign content = item.content | metafield_tag
                    -%}

                    <div class="flex flex-col gap-2 justify-center items-center">
                      <div class="w-[10em] sm:w-[6em] md:w-[6em] h-[5em] sm:h-[3em] md:h-[3em]">
                        <img
                          src="{{ poster | image_url: width: 800 }}"
                          class="w-full h-full object-cover"
                          alt=""
                          width="800"
                          height=""
                        >
                      </div>
                      <div class="text-[1.5em] sm:text-[1.2em] md:text-[1.2em] opacity-80 leading-[1]">
                        {{ title }}
                      </div>
                    </div>
                    <div class="text-[1em] opacity-60 text-pretty *:flex *:flex-col *:gap-[0.25em]">
                      {{ content }}
                    </div>
                  </div>
                </div>
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
{%- endunless -%}
