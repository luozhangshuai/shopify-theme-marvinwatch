{% liquid
  assign details = page.metafields.custom.details.value
  assign timeline_anchor = '#movement-timeline'
  assign archive_anchor = '#movement-archive'
  assign heritage_anchor = '#movement-heritage'

  for item in details
    if item.name == 'movement'
      assign image1 = item.image1
      assign image2 = item.image2
      assign image3 = item.image3
      assign image4 = item.image4
      assign image5 = item.image5
      assign image6 = item.image6
    endif
  endfor
%}
<section
  class="movement-landing"
  style="
    --movement-bg: {{ section.settings.background_color }};
    --movement-surface: {{ section.settings.surface_color }};
    --movement-surface-alt: {{ section.settings.surface_alt_color }};
    --movement-accent: {{ section.settings.accent_color }};
    --movement-accent-2: {{ section.settings.accent_secondary_color }};
    --movement-text: {{ section.settings.text_color }};
    --movement-muted: {{ section.settings.muted_text_color }};
    --movement-border: {{ section.settings.border_color }};
    --movement-top: {{ section.settings.padding_top }}px;
    --movement-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <style>
    .movement-landing {
      background: var(--movement-bg);
      color: var(--movement-text);
      padding: var(--movement-top) 0 var(--movement-bottom);
      font-family: Inter, Helvetica, Arial, sans-serif;
    }

    .movement-landing__container {
      width: min(100%, 1280px);
      margin: 0 auto;
      padding: 0 16px;
    }

    .movement-landing__section {
      margin-bottom: 16px;
      border: 1px solid rgba(255, 255, 255, 0.08);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.015), rgba(255, 255, 255, 0.01)),
        var(--movement-surface);
      overflow: hidden;
    }

    .movement-landing__hero {
      position: relative;
      min-height: 640px;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 88px 28px;
      background:
        radial-gradient(circle at center, rgba(212, 175, 55, 0.14), transparent 28%),
        linear-gradient(180deg, rgba(10, 10, 10, 0.72), rgba(10, 10, 10, 0.92)),
        var(--movement-surface);
    }

    .movement-landing__hero::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(180deg, rgba(200, 16, 46, 0.05), transparent 36%),
        repeating-linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.02) 0,
          rgba(255, 255, 255, 0.02) 1px,
          transparent 1px,
          transparent 7px
        );
      pointer-events: none;
    }

    .movement-landing__hero-content {
      position: relative;
      z-index: 1;
      max-width: 980px;
    }

    .movement-landing__eyebrow {
      margin: 0 0 14px;
      color: var(--movement-accent);
      text-transform: uppercase;
      letter-spacing: 0.28em;
      font-size: 0.78rem;
      font-weight: 600;
    }

    .movement-landing__title,
    .movement-landing__section-title,
    .movement-landing__subsection-title {
      margin: 0;
      font-family: "Playfair Display", Georgia, "Times New Roman", serif;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      line-height: 1.05;
    }

    .movement-landing__title {
      font-size: clamp(2.5rem, 7vw, 6rem);
      text-shadow: 0 0 20px rgba(212, 175, 55, 0.25);
    }

    .movement-landing__section-title {
      font-size: clamp(2rem, 5vw, 4rem);
      text-align: center;
    }

    .movement-landing__subsection-title {
      font-size: clamp(1.8rem, 3vw, 2.8rem);
    }

    .movement-landing__nowrap {
      white-space: nowrap;
    }

    .movement-landing__hero-text,
    .movement-landing__hero-text p,
    .movement-landing__section-intro,
    .movement-landing__section-intro p,
    .movement-landing__body-text,
    .movement-landing__body-text p {
      margin: 18px auto 0;
      max-width: 860px;
      color: var(--movement-muted);
      line-height: 1.8;
      font-size: 1rem;
    }

    .movement-landing__divider {
      width: 96px;
      height: 4px;
      margin: 24px auto 0;
      background: linear-gradient(90deg, var(--movement-accent), var(--movement-accent-2));
    }

    .movement-landing__actions {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 16px;
      margin-top: 34px;
    }

    .movement-landing__button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 48px;
      padding: 12px 24px;
      border: 1px solid transparent;
      text-decoration: none;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      font-size: 0.8rem;
      font-weight: 700;
      transition: transform 0.2s ease, background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    }

    .movement-landing__button:hover {
      transform: translateY(-2px);
    }

    .movement-landing__button--gold {
      background: var(--movement-accent);
      color: #111;
      border-color: var(--movement-accent);
    }

    .movement-landing__button--ghost {
      border-color: #fff;
      color: #fff;
    }

    .movement-landing__button--ghost:hover {
      background: #fff;
      color: #111;
    }

    .movement-landing__button--dark {
      background: #fff;
      color: var(--movement-accent-2);
      border-color: #fff;
    }

    .movement-landing__button--light {
      border-color: #fff;
      color: #fff;
    }

    .movement-landing__header {
      text-align: center;
      padding: 64px 20px 22px;
    }

    .movement-landing__timeline {
      position: relative;
      padding: 0 24px 56px;
    }

    .movement-landing__timeline-center-line {
      position: absolute;
      left: 50%;
      top: 0;
      bottom: 0;
      width: 4px;
      transform: translateX(-50%);
      background: linear-gradient(180deg, var(--movement-accent), var(--movement-accent-2));
      display: none;
    }

    .movement-landing__timeline-entry {
      display: flex;
      flex-direction: column;
      align-items: center;
      margin-bottom: 64px;
    }

    .movement-landing__timeline-entry:last-child {
      margin-bottom: 0;
    }

    .movement-landing__timeline-column {
      width: 100%;
    }

    .movement-landing__timeline-column--text,
    .movement-landing__timeline-column--info {
      margin-bottom: 20px;
      text-align: left;
    }

    .movement-landing__timeline-column--info {
      margin-bottom: 0;
    }

    .movement-landing__timeline-dot-wrap {
      width: 48px;
      display: flex;
      justify-content: center;
      margin-bottom: 20px;
    }

    .movement-landing__timeline-info-card {
      padding: 24px;
      background: var(--movement-surface-alt);
      border: 1px solid rgba(255, 255, 255, 0.12);
      border-radius: 12px;
    }

    .movement-landing__timeline-year {
      margin: 0 0 12px;
      color: var(--movement-accent);
      font-family: "Playfair Display", Georgia, "Times New Roman", serif;
      font-size: 1.9rem;
      line-height: 1.1;
    }

    .movement-landing__timeline-phase-title,
    .movement-landing__archive-card-title,
    .movement-landing__influence-card-title,
    .movement-landing__signature-card-title {
      margin: 0;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      line-height: 1.35;
      font-size: 1.05rem;
    }

    .movement-landing__timeline-phase-text,
    .movement-landing__archive-card-text,
    .movement-landing__influence-card-text,
    .movement-landing__signature-card-text,
    .movement-landing__timeline-list li,
    .movement-landing__brand-list p {
      margin: 10px 0 0;
      color: var(--movement-muted);
      line-height: 1.7;
      font-size: 0.92rem;
    }

    .movement-landing__timeline-list {
      list-style: none;
      margin: 14px 0 0;
      padding: 0;
    }

    .movement-landing__timeline-list-title {
      margin: 0 0 8px;
      color: var(--movement-text);
      font-size: 1rem;
      font-weight: 700;
      letter-spacing: 0.02em;
    }

    .movement-landing__timeline-marker {
      position: relative;
      z-index: 1;
      width: 24px;
      height: 24px;
      margin: 0 auto;
      border-radius: 50%;
      background: var(--movement-accent);
      border: 4px solid var(--movement-bg);
      box-shadow: 0 0 0 2px rgba(255, 255, 255, 0.08);
    }

    .movement-landing__archive-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 24px;
      padding: 0 24px 56px;
    }

    .movement-landing__archive-grid > * {
      flex: 0 0 calc((100% - 48px) / 3);
      min-width: 0;
    }

    .movement-landing__archive-card,
    .movement-landing__influence-card,
    .movement-landing__signature-card,
    .movement-landing__quote-card,
    .movement-landing__brand-panel {
      background: rgba(18, 18, 18, 0.86);
      border-radius: 12px;
      overflow: hidden;
    }

    .movement-landing__archive-card:hover,
    .movement-landing__signature-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 16px 32px rgba(212, 175, 55, 0.12);
    }

    .movement-landing__archive-card,
    .movement-landing__signature-card {
      transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    }

    .movement-landing__archive-card--highlight {
      border-color: rgba(200, 16, 46, 0.5);
    }

    .movement-landing__archive-image {
      aspect-ratio: 4 / 3;
      background: #090909;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 2px solid #1e1e1e;
    }

    .movement-landing__archive-image img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: contain;
    }

    .movement-landing__archive-content,
    .movement-landing__influence-content,
    .movement-landing__signature-content,
    .movement-landing__quote-content,
    .movement-landing__brand-content {
      padding: 24px;
    }

    .movement-landing__archive-label,
    .movement-landing__influence-label {
      margin: 0 0 12px;
      color: var(--movement-accent);
      text-transform: uppercase;
      letter-spacing: 0.16em;
      font-size: 0.72rem;
      font-weight: 700;
    }

    .movement-landing__tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 18px;
    }

    .movement-landing__tag {
      display: inline-flex;
      align-items: center;
      min-height: 28px;
      padding: 6px 12px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.06);
      color: var(--movement-text);
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .movement-landing__tag--accent {
      background: rgba(200, 16, 46, 0.16);
      color: var(--movement-accent-2);
    }

    .movement-landing__influence-layout,
    .movement-landing__brand-layout {
      display: flex;
      flex-wrap: wrap;
      padding: 0 24px 56px;
      align-items: stretch;
    }

    .movement-landing__influence-layout > :first-child {
      flex: 1 1 calc((100% - 28px) * 1.05 / 2.05);
      min-width: 0;
    }

    .movement-landing__influence-layout > :last-child {
      flex: 1 1 calc((100% - 28px) * 1 / 2.05);
      min-width: 0;
    }

    .movement-landing__brand-layout > :first-child {
      flex: 1 1 calc((100% - 28px) * 1.05 / 2.05);
      min-width: 0;
    }

    .movement-landing__brand-layout > :last-child {
      flex: 1 1 calc((100% - 28px) * 1 / 2.05);
      min-width: 0;
    }

    .movement-landing__chart-panel {
      padding: 28px;
      background: rgba(10, 10, 10, 0.9);
    }

    .movement-landing__chart-title {
      margin: 0 0 20px;
      text-align: center;
      font-family: "Playfair Display", Georgia, "Times New Roman", serif;
      font-size: 1.15rem;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .movement-landing__chart-canvas-wrap {
      position: relative;
      max-width: 420px;
      height: 420px;
      margin: 0 auto;
    }

    .movement-landing__chart-caption {
      margin: 18px 0 0;
      color: var(--movement-muted);
      font-size: 0.85rem;
      line-height: 1.65;
      text-align: center;
    }

    .movement-landing__influence-list {
      display: flex;
      flex-direction: column;
      gap: 18px;
    }

    .movement-landing__influence-flow {
      display: flex;
      align-items: center;
      gap: 14px;
      margin-top: 16px;
    }

    .movement-landing__flow-node {
      width: 52px;
      height: 52px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 0.78rem;
      background: var(--movement-accent);
      color: #111;
      text-transform: uppercase;
    }

    .movement-landing__flow-node--light {
      background: #fff;
      color: #111;
      font-size: 0.64rem;
    }

    .movement-landing__flow-arrow {
      color: var(--movement-accent);
      font-size: 1.6rem;
      line-height: 1;
    }

    .movement-landing__influence-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 16px;
    }

    .movement-landing__influence-grid > * {
      flex: 1 1 calc((100% - 20px) / 3);
      min-width: 0;
    }

    .movement-landing__influence-mini {
      padding: 14px 10px;
      border-radius: 8px;
      background: rgba(255, 255, 255, 0.04);
      text-align: center;
    }

    .movement-landing__influence-mini strong {
      display: block;
      font-size: 0.85rem;
      line-height: 1.4;
    }

    .movement-landing__influence-mini span {
      display: block;
      margin-top: 4px;
      color: var(--movement-muted);
      font-size: 0.72rem;
      line-height: 1.45;
    }

    .movement-landing__quote-card {
      background: var(--movement-surface-alt);
    }

    .movement-landing__influence-card--gold {
      border-left: 4px solid var(--movement-accent);
    }

    .movement-landing__influence-card--red {
      border-left: 4px solid var(--movement-accent-2);
    }

    .movement-landing__quote-text {
      margin: 0;
      color: #d8d8d8;
      line-height: 1.75;
      font-size: 0.98rem;
      font-style: italic;
    }

    .movement-landing__quote-source {
      margin: 16px 0 0;
      color: var(--movement-accent);
      font-weight: 600;
      letter-spacing: 0.04em;
    }

    .movement-landing__signatures-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 20px;
      padding: 0 24px 34px;
    }

    .movement-landing__signatures-grid > * {
      flex: 0 0 calc((100% - 60px) / 4);
      min-width: 0;
    }

    .movement-landing__signature-card {
      text-align: center;
    }

    .movement-landing__signature-icon {
      width: 64px;
      height: 64px;
      margin: 0 auto 20px;
      border-radius: 50%;
      background: rgba(212, 175, 55, 0.1);
      border: 1px solid rgba(212, 175, 55, 0.45);
      color: var(--movement-accent);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.86rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .movement-landing__brand-panel {
      padding: 36px;
    }

    .movement-landing__brand-list {
      margin-top: 22px;
    }

    .movement-landing__brand-row {
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .movement-landing__brand-row + .movement-landing__brand-row {
      margin-top: 14px;
    }

    .movement-landing__brand-mark {
      width: 42px;
      height: 42px;
      border-radius: 50%;
      background: var(--movement-accent);
      color: #111;
      display: flex;
      align-items: center;
      justify-content: center;
      flex: 0 0 auto;
      font-weight: 700;
      font-size: 1rem;
    }

    .movement-landing__brand-mark--invert {
      transform: rotate(180deg);
    }

    .movement-landing__brand-badge {
      min-height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 36px;
      background: rgba(18, 18, 18, 0.86);
      border-radius: 12px;
    }

    .movement-landing__brand-badge-circle {
      width: min(100%, 270px);
      aspect-ratio: 1;
      border-radius: 50%;
      border: 4px solid var(--movement-accent);
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 26px;
      background: rgba(30, 30, 30, 0.9);
    }

    .movement-landing__brand-badge-inner {
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .movement-landing__brand-badge-m {
      color: var(--movement-accent);
      font-family: "Playfair Display", Georgia, "Times New Roman", serif;
      font-size: 4.3rem;
      line-height: 0.9;
      font-weight: 700;
    }

    .movement-landing__brand-badge-m--invert {
      transform: rotate(180deg);
      margin-top: -8px;
    }

    .movement-landing__brand-badge-text {
      margin-top: 16px;
      color: var(--movement-muted);
      text-transform: uppercase;
      letter-spacing: 0.14em;
      font-size: 0.74rem;
      line-height: 1.5;
    }

    .movement-landing__cta {
      margin-top: 16px;
      padding: 56px 24px;
      text-align: center;
      border: 1px solid rgba(255, 255, 255, 0.08);
      background: linear-gradient(180deg, #c8102e 0%, #9f0921 100%);
      color: #fff;
    }

    .movement-landing__cta .movement-landing__eyebrow {
      color: #fff;
    }

    .movement-landing__cta .movement-landing__body-text,
    .movement-landing__cta .movement-landing__body-text p {
      color: rgba(255, 255, 255, 0.92);
      max-width: 760px;
    }

    .movement-landing__placeholder {
      min-height: 280px;
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
      text-align: center;
      color: var(--movement-muted);
      background: linear-gradient(135deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02));
    }

    @media screen and (max-width: 1100px) {
      .movement-landing__archive-grid > *,
      .movement-landing__signatures-grid > * {
        flex-basis: calc((100% - 24px) / 2);
      }

      .movement-landing__influence-layout > :first-child,
      .movement-landing__influence-layout > :last-child,
      .movement-landing__brand-layout > :first-child,
      .movement-landing__brand-layout > :last-child {
        flex-basis: 100%;
      }
    }

    @media screen and (max-width: 989px) {
      .movement-landing__timeline {
        padding-left: 20px;
        padding-right: 20px;
      }
    }

    @media screen and (max-width: 749px) {
      .movement-landing__hero {
        min-height: 520px;
        padding: 64px 18px;
      }

      .movement-landing__header {
        padding: 44px 18px 18px;
      }

      .movement-landing__timeline,
      .movement-landing__archive-grid,
      .movement-landing__influence-layout,
      .movement-landing__signatures-grid,
      .movement-landing__brand-layout {
        padding-left: 14px;
        padding-right: 14px;
      }

      .movement-landing__archive-grid > *,
      .movement-landing__signatures-grid > * {
        flex-basis: 100%;
      }

      .movement-landing__timeline-info-card {
        padding: 22px;
      }

      .movement-landing__chart-canvas-wrap {
        max-width: 100%;
        height: 500px;
      }

      .movement-landing__influence-grid > * {
        flex-basis: 100%;
      }

      .movement-landing__cta {
        padding: 44px 18px;
      }
    }

    @media screen and (min-width: 750px) {
      .movement-landing__timeline-center-line {
        display: block;
      }

      .movement-landing__timeline-entry {
        flex-direction: row;
        margin-bottom: 96px;
      }

      .movement-landing__timeline-entry--reverse {
        flex-direction: row-reverse;
      }

      .movement-landing__timeline-column {
        width: 50%;
      }

      .movement-landing__timeline-column--text,
      .movement-landing__timeline-column--info {
        margin-bottom: 0;
      }

      .movement-landing__timeline-entry:not(.movement-landing__timeline-entry--reverse) .movement-landing__timeline-column--text {
        padding-right: 48px;
        text-align: right;
      }

      .movement-landing__timeline-entry:not(.movement-landing__timeline-entry--reverse) .movement-landing__timeline-column--info {
        padding-left: 48px;
      }

      .movement-landing__timeline-entry--reverse .movement-landing__timeline-column--text {
        padding-left: 48px;
        text-align: left;
      }

      .movement-landing__timeline-entry--reverse .movement-landing__timeline-column--info {
        padding-right: 48px;
      }

      .movement-landing__timeline-dot-wrap {
        width: 48px;
        flex: 0 0 48px;
        margin-bottom: 0;
      }
    }
  </style>

  <div class="movement-landing__container">
    <section class="movement-landing__hero movement-landing__section">
      <div class="movement-landing__hero-content">
        <p class="movement-landing__eyebrow">Swiss made since 1850</p>
        <h1 class="movement-landing__title">
          The engine<br>
          Behind time
        </h1>
        <div class="movement-landing__hero-text">
          <p>
            For more than a century, MARVIN has not only crafted watches, it has engineered
            movements. From early hand-wound calibers to advanced automatic systems, our legacy
            helped shape an important chapter of Swiss watchmaking history.
          </p>
        </div>
        <div class="movement-landing__actions">
          <a
            class="movement-landing__button movement-landing__button--gold"
