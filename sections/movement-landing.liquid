  <script>
    (function () {
      var currentScript = document.currentScript;
      var root = currentScript ? currentScript.closest('.movement-landing') : null;

      function initChart() {
        var canvas = root ? root.querySelector('[data-movement-influence-chart]') : null;
        if (!canvas || canvas.dataset.initialized === 'true' || !window.Chart) return;

        canvas.dataset.initialized = 'true';
        var isMobile = window.matchMedia('(max-width: 749px)').matches;

        new window.Chart(canvas, {
          type: 'doughnut',
          data: {
            labels: [
              'MARVIN Original Design',
              'Zenith 2310/2320',
              'Longines 490',
              'Chronoswiss C112',
              'Girard-Perregaux GP805',
              'Other Derivatives'
            ],
            datasets: [
              {
                data: [35, 20, 15, 10, 10, 10],
                backgroundColor: ['#C8102E', '#D4AF37', '#FFFFFF', '#CCCCCC', '#999999', '#666666'],
                borderWidth: 0,
                cutout: '60%'
              }
            ]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: {
                position: 'bottom',
                labels: {
                  color: '#FFFFFF',
                  boxWidth: isMobile ? 10 : 14,
                  padding: isMobile ? 10 : 16,
                  font: {
                    family: 'Inter, Helvetica, Arial, sans-serif',
                    size: isMobile ? 10 : 12
                  }
                }
              }
            }
          }
        });
      }

      if (window.Chart) {
        initChart();
        return;
      }

      function onLibraryReady() {
        window.__movementChartReady = true;
        document.removeEventListener('movement-chart-ready', initChart);
        initChart();
      }

      if (window.__movementChartReady) {
        initChart();
        return;
      }

      document.addEventListener('movement-chart-ready', initChart, { once: true });

      var existingScript = document.getElementById('movement-chartjs-loader');
      if (!existingScript) {
        existingScript = document.createElement('script');
        existingScript.id = 'movement-chartjs-loader';
        existingScript.src = 'https://cdn.jsdelivr.net/npm/chart.js@4.4.8/dist/chart.umd.min.js';
        existingScript.onload = function () {
          onLibraryReady();
          document.dispatchEvent(new Event('movement-chart-ready'));
        };
        document.head.appendChild(existingScript);
      }
    })();
  </script>
</section>

