{% schema %}
{
  "name": "Marvin Footer",
  "tag": "section",
  "enabled_on": { "groups": ["footer"] },
  "blocks": [
    { "type": "_divide" },
    { "type": "@app" },
    { "type": "marvin-menu" },
    { "type": "payment-icons" },
    { "type": "text" },
    { "type": "logo" }
  ],
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "配色方案",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "顶部内边距",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "底部内边距",
      "default": 40
    }
  ],
  "presets": [{ "name": "Marvin Footer" }]
}
{% endschema %}

{% render 'vite-tag', entry: 'marvin-footer.css' %}
<div class="marvin-footer color-{{ section.settings.color_scheme }}"
     style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">

  <div class="page-width">
    <div class="marvin-footer__content flex flex-col gap-10">
      {% content_for 'blocks' %}
    </div>
  </div>
</div>

