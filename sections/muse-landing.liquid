{% liquid
  assign details = page.metafields.custom.details.value
  assign muse_landing_target_url = '/products/saint-patrick-worldtimer-automatic-x-huawei-smart-movement'

  assign story_points = section.settings.story_points | newline_to_br | split: '<br />'

  for item in details
    if item.name == 'muse'
      assign usa250_image_1 = item.muse1
      assign usa250_image_2 = item.muse2
      assign usa250_image_3 = item.muse3
      assign usa250_image_4 = item.muse4
      assign usa250_image_5 = item.muse5
      assign usa250_image_6 = item.muse6

      assign usa250_image_41 = item.muse41
      assign usa250_image_42 = item.muse42
      assign usa250_image_51 = item.muse51
      assign usa250_image_52 = item.muse52
      assign usa250_image_53 = item.muse53
      assign usa250_image_31 = item.muse7
      assign usa250_image_32 = item.muse8
      assign usa250_image_10 = item.muse10
    endif
  endfor
%}

<section
  class="muse-awards-landing"
  style="
    --muse-bg: {{ section.settings.background_color }};
    --muse-surface: {{ section.settings.surface_color }};
    --muse-accent: {{ section.settings.accent_color }};
    --muse-text: {{ section.settings.text_color }};
    --muse-muted: {{ section.settings.muted_text_color }};
    --muse-padding-top: {{ section.settings.padding_top }}px;
    --muse-padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <style>
    .muse-awards-landing {
      background: var(--muse-bg);
      color: var(--muse-text);
      padding: var(--muse-padding-top) 0 var(--muse-padding-bottom);
    }

    .muse-awards-landing__container {
      width: min(100%, 1320px);
      margin: 0 auto;
      padding: 0 16px;
    }

    .muse-awards-landing__grid {
      display: flex;
      flex-wrap: wrap;
      align-items: stretch;
      gap: 12px;
    }

    .muse-awards-landing__panel {
      background: var(--muse-surface);
      overflow: hidden;
      position: relative;
    }

    .muse-awards-landing__content {
      padding: 28px;
    }

    .muse-awards-landing__eyebrow {
      color: var(--muse-accent);
      font-size: 0.75rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      margin: 0 0 12px;
    }

    .muse-awards-landing__title {
      font-size: clamp(1.9rem, 4vw, 4.5rem);
      line-height: 0.95;
      margin: 0;
      color: var(--muse-accent);
    }

    .muse-awards-landing__subtitle {
      font-size: clamp(1.3rem, 2.4vw, 2.25rem);
      line-height: 1.1;
      margin: 16px 0 0;
      color: var(--muse-text);
    }

    .muse-awards-landing__copy,
    .muse-awards-landing__copy p {
      color: var(--muse-muted);
      font-size: 0.95rem;
      line-height: 1.7;
      margin: 14px 0 0;
    }

    .muse-awards-landing__hero {
      flex: 1 1 100%;
      min-height: 520px;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 32px;
      background:
        radial-gradient(circle at center, rgba(0, 166, 158, 0.22), transparent 48%),
        linear-gradient(90deg, #082421 0%, #074f4c 42%, #021617 100%);
    }

    .muse-awards-landing__hero-link {
      color: inherit;
      text-decoration: none;
      cursor: pointer;
    }

    .muse-awards-landing__hero-copy {
      flex: 1 1 52%;
      max-width: 520px;
    }

    .muse-awards-landing__hero-media {
      flex: 1 1 calc(48% - 32px);
    }

    .muse-awards-landing__badge {
      max-width: 200px;
      margin-bottom: 18px;
    }

    .muse-awards-landing__hero-media,
    .muse-awards-landing__media,
    .muse-awards-landing__gallery-item {
      min-height: 100%;
    }

    .muse-awards-landing__media img,
    .muse-awards-landing__hero-media img,
    .muse-awards-landing__gallery-item img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .muse-awards-landing__placeholder {
      min-height: 240px;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
      background:
        linear-gradient(135deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.02)),
        #111;
      color: var(--muse-muted);
      text-align: center;
      font-size: 0.9rem;
    }

    .muse-awards-landing__award {
      flex: 0 1 calc((100% - 12px) * 5 / 12);
    }

    .muse-awards-landing__about {
      flex: 0 1 calc((100% - 12px) * 7 / 12);
    }

    .muse-awards-landing__section-title {
      font-size: clamp(1.5rem, 2vw, 2.35rem);
      line-height: 1.1;
      margin: 0;
      color: var(--muse-text);
    }

    .muse-awards-landing__highlights {
      display: flex;
      flex-wrap: wrap;
      gap: 16px;
      margin-top: 28px;
    }

    .muse-awards-landing__highlight {
      flex: 1 1 calc((100% - 32px) / 3);
      border-top: 1px solid rgba(184, 147, 61, 0.35);
      padding-top: 16px;
    }

    .muse-awards-landing__highlight-icon {
      display: block;
      width: 50px;
      height: 50px;
      margin-bottom: 12px;
      object-fit: contain;
    }

    .muse-awards-landing__highlight strong {
      display: block;
      color: var(--muse-accent);
      font-size: 0.85rem;
      line-height: 1.4;
      margin-bottom: 8px;
    }

    .muse-awards-landing__highlight span {
      color: var(--muse-muted);
      font-size: 0.84rem;
      line-height: 1.6;
      display: block;
    }

    .muse-awards-landing__story {
      flex: 0 1 calc((100% - 12px) / 2);
      display: flex;
      align-items: center;
    }

    .muse-awards-landing__story-media {
      flex: 0 1 calc((100% - 12px) / 2);
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 420px;
    }

    .muse-awards-landing__story-media img {
      width: 400px;
      height: 400px;
      max-width: min(100%, 400px);
      max-height: 100%;
      object-fit: contain;
    }

    .muse-awards-landing__points {
      list-style: none;
      margin: 24px 0 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .muse-awards-landing__points li {
      position: relative;
      color: var(--muse-text);
      line-height: 1.6;
      font-size: 0.95rem;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .muse-awards-landing__point-icon {
      flex: 0 0 20px;
      width: 20px;
      height: 20px;
      object-fit: contain;
    }

    .muse-awards-landing__brand {
      flex: 1;
      display: flex;
      align-items: center;
    }

    .muse-awards-landing__brand-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 28px;
      align-items: center;
    }

    .muse-awards-landing__brand-grid > *:first-child {
      flex: 0 0 min(180px, 100%);
    }

    .muse-awards-landing__brand-grid > *:last-child {
      flex: 1 1 320px;
    }

    .muse-awards-landing__brand-logo {
      max-width: 180px;
    }

    .muse-awards-landing__brand-media {
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .muse-awards-landing__brand-media img {
      width: 400px;
      height: auto;
      max-width: 100%;
      object-fit: contain;
    }

    .muse-awards-landing__gallery {
      flex: 1 1 100%;
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
    }

    .muse-awards-landing__gallery-item {
      flex: 1 1 calc((100% - 24px) / 3);
      min-height: 220px;
      background: #111;
    }

    .muse-awards-landing__bottom-cta {
      flex: 1 1 100%;
      min-height: 260px;
      position: relative;
      isolation: isolate;
      background: #111;
    }

    .muse-awards-landing__bottom-cta img {
      display: block;
      width: 100%;
      height: 100%;
      min-height: 260px;
      object-fit: cover;
    }

    .muse-awards-landing__bottom-cta-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, rgba(0, 0, 0, 0.12) 0%, rgba(0, 0, 0, 0.65) 100%);
      z-index: 1;
    }

    .muse-awards-landing__bottom-cta-content {
      position: absolute;
      inset: 0;
      z-index: 2;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 32px 24px;
    }

    .muse-awards-landing__bottom-cta-inner {
      max-width: 680px;
    }

    .muse-awards-landing__bottom-cta-title {
      margin: 0;
      color: #fff;
      font-size: clamp(1.6rem, 3vw, 2.4rem);
      line-height: 1.15;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .muse-awards-landing__bottom-cta-text,
    .muse-awards-landing__bottom-cta-text p {
      margin: 14px 0 0;
      color: rgba(255, 255, 255, 0.86);
      font-size: 0.95rem;
      line-height: 1.7;
    }

    .muse-awards-landing__button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 190px;
      min-height: 48px;
      margin-top: 22px;
      padding: 12px 28px;
      border: 1px solid rgba(255, 255, 255, 0.85);
      color: #fff;
      text-decoration: none;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-size: 0.78rem;
      transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    }

    .muse-awards-landing__button:hover {
      background: #fff;
      border-color: #fff;
      color: #111;
    }

    @media screen and (max-width: 989px) {
      .muse-awards-landing__hero,
      .muse-awards-landing__award,
      .muse-awards-landing__about,
      .muse-awards-landing__story,
      .muse-awards-landing__story-media,
      .muse-awards-landing__brand,
      .muse-awards-landing__brand-media,
      .muse-awards-landing__gallery {
        flex-basis: 100%;
      }

      .muse-awards-landing__hero {
        min-height: auto;
        display: block;
      }

      .muse-awards-landing__highlights,
      .muse-awards-landing__gallery,
      .muse-awards-landing__brand-grid {
        flex-direction: column;
      }

      .muse-awards-landing__brand {
        align-items: flex-start;
        display: block;
      }

      .muse-awards-landing__brand-grid {
        gap: 10px;
      }

      .muse-awards-landing__content.muse-awards-landing__brand-grid {
        padding: 10px 16px;
      }

      .muse-awards-landing__brand-grid > *:first-child,
      .muse-awards-landing__brand-grid > *:last-child {
        flex: none;
        width: 100%;
      }

      .muse-awards-landing__gallery {
        flex-wrap: nowrap;
        align-items: stretch;
      }

      .muse-awards-landing__content {
        padding: 22px 18px;
      }

      .muse-awards-landing__highlight,
      .muse-awards-landing__gallery-item,
      .muse-awards-landing__hero-copy,
      .muse-awards-landing__hero-media {
        flex-basis: 100%;
        max-width: 100%;
      }

      .muse-awards-landing__hero-copy,
      .muse-awards-landing__hero-media {
        width: 100%;
        flex: none;
      }

      .muse-awards-landing__hero-media {
        width: 100%;
        min-height: 280px;
      }

      .muse-awards-landing__hero-media img {
        width: 100%;
        height: auto;
        min-height: 280px;
        object-fit: cover;
      }

      .muse-awards-landing__gallery-item {
        width: 100%;
      }

      .muse-awards-landing__gallery-item {
        min-height: 180px;
      }

      .muse-awards-landing__bottom-cta,
      .muse-awards-landing__bottom-cta img {
        min-height: 320px;
      }

      .muse-awards-landing__bottom-cta-content {
        padding: 28px 16px 40px;
      }

      .muse-awards-landing__button {
        min-width: 170px;
        margin-top: 18px;
      }
    }
  </style>

  <div class="muse-awards-landing__container">
    <div class="muse-awards-landing__grid">
      <a
        class="muse-awards-landing__hero muse-awards-landing__panel muse-awards-landing__hero-link"
        href="{{ muse_landing_target_url }}"
      >
        <div class="muse-awards-landing__content muse-awards-landing__hero-copy">
          {{ usa250_image_1 | image_url: width: 800 | image_tag: loading: 'lazy' }}

          {% if section.settings.hero_subtitle != blank %}
            <h2 class="muse-awards-landing__subtitle">{{ section.settings.hero_subtitle }}</h2>
          {% endif %}

          {% if section.settings.hero_desc != blank %}
            <div class="muse-awards-landing__copy">{{ section.settings.hero_desc }}</div>
          {% endif %}
        </div>
        <div class="muse-awards-landing__hero-media">
          {% if usa250_image_2 != blank %}
            {{ usa250_image_2 | image_url: width: 1600 | image_tag: loading: 'lazy' }}
          {% else %}
            <div class="muse-awards-landing__placeholder">Upload hero product image</div>
          {% endif %}
        </div>
      </a>


      <div class="muse-awards-landing__award muse-awards-landing__panel muse-awards-landing__media">
        <a href="https://design.museaward.com/winners-info.php?id=36734" target="_blank">
          {% if usa250_image_3 != blank %}
            {{ usa250_image_3 | image_url: width: 1200 | image_tag: loading: 'lazy' }}
          {% else %}
            <div class="muse-awards-landing__placeholder">Upload award image</div>
          {% endif %}
        </a>
      </div>

      <div class="muse-awards-landing__about muse-awards-landing__panel">
        <div class="muse-awards-landing__content">
          <p class="muse-awards-landing__eyebrow">{{ section.settings.about_caption }}</p>
           {% if section.settings.about_desc != blank %}
            <div class="muse-awards-landing__copy">{{ section.settings.about_desc }}</div>
          {% endif %}

          <div class="muse-awards-landing__highlights">
            {% for index in (1..3) %}
              {% liquid
                assign title_key = 'highlight_' | append: index | append: '_title'
                assign text_key = 'highlight_' | append: index | append: '_text'
                assign highlight_title = section.settings[title_key]
                assign highlight_text = section.settings[text_key]
                assign highlight_icon = usa250_image_4
                case index
                  when 2
                    assign highlight_icon = usa250_image_5
                  when 3
                    assign highlight_icon = usa250_image_6  
                endcase
              %}
              {% if highlight_title != blank or highlight_text != blank %}
                <div class="muse-awards-landing__highlight">
                  {% if highlight_icon != blank %}
                    {{
                      highlight_icon
                      | image_url: width: 50
                      | image_tag: class: 'muse-awards-landing__highlight-icon', loading: 'lazy'
                    }}
                  {% endif %}
                  {% if highlight_title != blank %}
                    <strong>{{ highlight_title }}</strong>
                  {% endif %}
                  {% if highlight_text != blank %}
                    <span>{{ highlight_text }}</span>
                  {% endif %}
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>

      <div class="muse-awards-landing__story muse-awards-landing__panel">
        <div class="muse-awards-landing__content">
          {% if section.settings.story_caption != blank %}
            <p class="muse-awards-landing__eyebrow">{{ section.settings.story_caption }}</p>
          {% endif %}

          {% if section.settings.story_title != blank %}
            <h2 class="muse-awards-landing__section-title">{{ section.settings.story_title }}</h2>
          {% endif %}

          {% if section.settings.story_subtitle != blank %}
            <h3 class="muse-awards-landing__subtitle">{{ section.settings.story_subtitle }}</h3>
          {% endif %}

          {% if section.settings.story_points != blank %}
            <ul class="muse-awards-landing__points">
              {% for point in story_points %}
                {% assign point_text = point | strip %}
                {% if point_text != blank %}
                  <li>
                    {{
                      usa250_image_31
                      | image_url: width: 20
                      | image_tag: class: 'muse-awards-landing__point-icon', loading: 'lazy'
                    }}
                    {{ point_text }}
                  </li>
                {% endif %}
              {% endfor %}
            </ul>
          {% endif %}
        </div>
      </div>

      <div class="muse-awards-landing__story-media muse-awards-landing__panel muse-awards-landing__media">
        {{ usa250_image_32 | image_url: width: 700 | image_tag: loading: 'lazy' }}
      </div>

      <div class="muse-awards-landing__brand muse-awards-landing__panel">
        <div class="muse-awards-landing__content muse-awards-landing__brand-grid">
          <div>
              {{
                usa250_image_41
                | image_url: width: 360
                | image_tag: class: 'muse-awards-landing__brand-logo', loading: 'lazy'
              }}  
          </div>

          <div>
            {% if section.settings.brand_description != blank %}
              <div class="muse-awards-landing__copy">{{ section.settings.brand_description }}</div>
            {% endif %}
          </div>
        </div>
      </div>

      <div class="muse-awards-landing__brand-media muse-awards-landing__panel muse-awards-landing__media">
        {{ usa250_image_42 | image_url: width: 1200 | image_tag: loading: 'lazy' }}
      </div>

      <div class="muse-awards-landing__gallery">
        <div class="muse-awards-landing__gallery-item muse-awards-landing__panel">
          {{ usa250_image_51 | image_url: width: 960 | image_tag: loading: 'lazy' }}
        </div>
        <div class="muse-awards-landing__gallery-item muse-awards-landing__panel">
          {{ usa250_image_52 | image_url: width: 960 | image_tag: loading: 'lazy' }}
        </div>
        <div class="muse-awards-landing__gallery-item muse-awards-landing__panel">
          {{ usa250_image_53 | image_url: width: 960 | image_tag: loading: 'lazy' }}
        </div>
      </div>

      <div class="muse-awards-landing__bottom-cta muse-awards-landing__panel">
        {{ usa250_image_10 | image_url: width: 2200 | image_tag: loading: 'lazy' }}
        <div class="muse-awards-landing__bottom-cta-overlay"></div>
        <div class="muse-awards-landing__bottom-cta-content">
          <div class="muse-awards-landing__bottom-cta-inner">
            {% if section.settings.bottom_cta_title != blank %}
              <h2 class="muse-awards-landing__bottom-cta-title">{{ section.settings.bottom_cta_title }}</h2>
            {% endif %}
            {% if section.settings.bottom_cta_text != blank %}
              <div class="muse-awards-landing__bottom-cta-text">{{ section.settings.bottom_cta_text }}</div>
            {% endif %}
            {% if section.settings.bottom_cta_button_label != blank %}
              <a
                class="muse-awards-landing__button"
                href="{{ muse_landing_target_url }}"
              >
                {{ section.settings.bottom_cta_button_label }}
              </a>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Muse awards landing",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#040404"
    },
    {
      "type": "color",
      "id": "surface_color",
      "label": "Card background",
      "default": "#090909"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#c39a3f"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Muted text",
      "default": "#c8c8c8"
    },
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "text",
      "id": "hero_subtitle",
      "label": "Hero subtitle",
      "default": "The standout feature is a single case system paired with two interchangeable modules."
    },
    {
      "type": "richtext",
      "id": "hero_desc",
      "label": "Hero description",
      "default": "<p>The standout feature is a single case system paired with two interchangeable modules.</p>"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "header",
      "content": "Award and about"
    },
    {
      "type": "image_picker",
      "id": "award_image",
      "label": "Award image"
    },
    {
      "type": "text",
      "id": "about_caption",
      "label": "About caption",
      "default": "ABOUT THE MUSE DESIGN AWARDS"
    },
    {
      "type": "richtext",
      "id": "about_desc",
      "label": "About description",
      "default": "<p>The MUSE Design Awards is an international competition that honorsexcellence in creativity. innovation and execution in design acrossa wide range of industries. Winners are selected by a panel of world-class professionals who evaluate entries on their ability to inspire,innovate and elevate the human experience.</p>"
    },
    {
      "type": "text",
      "id": "highlight_1_title",
      "label": "Highlight 1 title",
      "default": "GLOBAL RECOGNITION",
    },
    {
      "type": "text",
      "id": "highlight_1_text",
      "label": "Highlight 1 text",
      "default": "Celebrating outstanding design from around the world."
    },
    {
      "type": "text",
      "id": "highlight_2_title",
      "label": "Highlight 2 title",
      "default": "JURY EVALUATED"
    },
    {
      "type": "text",
      "id": "highlight_2_text",
      "label": "Highlight 2 text",
      "default": "Judged by leading experts architecture, design and innovation."
    },
    {
      "type": "text",
      "id": "highlight_3_title",
      "label": "Highlight 3 title",
      "default": "EXCELLENCE"
    },
    {
      "type": "text",
      "id": "highlight_3_text",
      "label": "Highlight 3 text",
      "default": "Honoring creativity that shapes the future of design."
