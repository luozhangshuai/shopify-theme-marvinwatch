<script>
  (function () {
    function normalizeCountdownDate(rawValue) {
      if (!rawValue) return null;

      var normalized = rawValue.trim();
      if (!normalized) return null;

      if (/^\d{4}-\d{2}-\d{2}$/.test(normalized)) {
        normalized += 'T23:59:59';
      } else if (/^\d{4}-\d{2}-\d{2}\s+\d{2}:\d{2}$/.test(normalized)) {
        normalized = normalized.replace(/\s+/, 'T') + ':00';
      } else if (/^\d{4}-\d{2}-\d{2}\s+\d{2}:\d{2}:\d{2}$/.test(normalized)) {
        normalized = normalized.replace(/\s+/, 'T');
      }

      var targetDate = new Date(normalized);
      if (Number.isNaN(targetDate.getTime())) return null;
      return targetDate;
    }

    function padCountdownValue(value) {
      return String(value).padStart(2, '0');
    }

    function updateCountdown(countdownElement, targetDate) {
      var daysEl = countdownElement.querySelector('[data-countdown-days]');
      var hoursEl = countdownElement.querySelector('[data-countdown-hours]');
      var minutesEl = countdownElement.querySelector('[data-countdown-minutes]');
      var secondsEl = countdownElement.querySelector('[data-countdown-seconds]');
      var timerId = null;

      if (!daysEl || !hoursEl || !minutesEl || !secondsEl) return null;

      function render() {
        var remainingMs = targetDate.getTime() - Date.now();

        if (remainingMs <= 0) {
          daysEl.textContent = '00';
          hoursEl.textContent = '00';
          minutesEl.textContent = '00';
          secondsEl.textContent = '00';
          return false;
        }

        var totalSeconds = Math.floor(remainingMs / 1000);
        var days = Math.floor(totalSeconds / 86400);
        var hours = Math.floor((totalSeconds % 86400) / 3600);
        var minutes = Math.floor((totalSeconds % 3600) / 60);
        var seconds = totalSeconds % 60;

        daysEl.textContent = padCountdownValue(days);
        hoursEl.textContent = padCountdownValue(hours);
        minutesEl.textContent = padCountdownValue(minutes);
        secondsEl.textContent = padCountdownValue(seconds);
        return true;
      }

      if (!render()) return null;

      timerId = window.setInterval(function () {
        if (!render()) {
          window.clearInterval(timerId);
        }
      }, 1000);

      return timerId;
    }

    document.querySelectorAll('[data-usa250-countdown]').forEach(function (countdownElement) {
      var targetDate = normalizeCountdownDate(countdownElement.getAttribute('data-countdown-end-at'));
      if (!targetDate) return;

      var timerId = updateCountdown(countdownElement, targetDate);
      if (!timerId) return;
    });
  })();
</script>

