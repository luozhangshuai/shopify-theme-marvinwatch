{% liquid
  assign details = page.metafields.custom.details.value

  assign value_points = section.settings.value_points | newline_to_br | split: '<br />'

  for item in details
    if item.name == 'usa250'
      assign section1bg = item.section1bg
      assign section2bg = item.section2bg
      assign section31 = item.section31
      assign section32 = item.section32
      assign section33 = item.section33
      assign section34 = item.section34
      assign section4bg = item.section4bg
      assign section5bg = item.section5bg
      assign section51 = item.section51
      assign section52 = item.section52
      assign section53 = item.section53
      assign section54 = item.section54
      assign section6bg = item.section6bg
      assign section61 = item.section61
      assign section7 = item.section7
      assign section71 = item.section71
      assign section8 = item.section8
      assign section9 = item.section9
      assign section10bg = item.section10bg
    endif
  endfor
%}

<section
  class="usa250-landing-root"
  style="
    --usa250-bg: {{ section.settings.background_color }};
    --usa250-surface: {{ section.settings.surface_color }};
    --usa250-surface-alt: {{ section.settings.surface_alt_color }};
    --usa250-panel: {{ section.settings.panel_color }};
    --usa250-accent: {{ section.settings.accent_color }};
    --usa250-text: {{ section.settings.text_color }};
    --usa250-muted: {{ section.settings.muted_text_color }};
    --usa250-border: {{ section.settings.border_color }};
    --usa250-top: {{ section.settings.padding_top }}px;
    --usa250-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <style>
    .usa250-landing-root {
      background: var(--usa250-bg);
      color: var(--usa250-text);
      padding: var(--usa250-top) 0 var(--usa250-bottom);
    }

    .usa250-landing-container {
      width: min(100%, 1440px);
      margin: 0 auto;
      padding: 0 16px;
    }

    .usa250-landing-hero-section,
    .usa250-landing-intro-section,
    .usa250-landing-features-section,
    .usa250-landing-story-section,
    .usa250-landing-values-section,
    .usa250-landing-heritage-section,
    .usa250-landing-detail-section,
    .usa250-landing-scenes-section,
    .usa250-landing-compare-section,
    .usa250-landing-cta-section {
      background: var(--usa250-surface);
      border-top: 1px solid var(--usa250-border);
      border-bottom: 1px solid var(--usa250-border);
    }

    .usa250-landing-hero-section {
      position: relative;
      min-height: 620px;
      overflow: hidden;
      background: radial-gradient(circle at 58% 25%, rgba(88, 132, 212, 0.28), transparent 24%),
        linear-gradient(180deg, rgba(3, 12, 33, 0.2), rgba(3, 12, 33, 0.55)), #071127;
      background-size: auto, auto, cover;
      background-position: center, center, center;
      background-repeat: no-repeat, no-repeat, no-repeat;
    }

    .usa250-landing-hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        90deg,
        rgba(4, 11, 28, 0.86) 0%,
        rgba(4, 11, 28, 0.45) 42%,
        rgba(4, 11, 28, 0.1) 100%
      );
      z-index: 1;
    }

    .usa250-landing-hero-content {
      position: relative;
      z-index: 2;
      min-height: 620px;
      display: flex;
      align-items: center;
      padding: 48px 32px;
    }

    .usa250-landing-hero-copy {
      width: 100%;
    }

    .usa250-landing-hero-eyebrow {
      margin: 0 0 14px;
      color: var(--usa250-accent);
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-size: 0.95rem;
      font-weight: 700;
    }

    .usa250-landing-hero-title {
      margin: 0;
      color: var(--usa250-text);
      font-size: clamp(2.4rem, 6vw, 5rem);
      line-height: 0.96;
      text-transform: uppercase;
      letter-spacing: 0.02em;
    }

    .usa250-landing-hero-subtitle {
      margin: 16px 0 0;
      color: var(--usa250-accent);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      font-size: clamp(1rem, 2vw, 1.6rem);
      font-weight: 700;
    }

    .usa250-landing-hero-text,
    .usa250-landing-hero-text p,
    .usa250-landing-intro-text,
    .usa250-landing-intro-text p,
    .usa250-landing-story-text,
    .usa250-landing-story-text p,
    .usa250-landing-values-text,
    .usa250-landing-values-text p {
      margin: 16px 0 0;
      color: var(--usa250-text);
      line-height: 1.7;
      font-size: 1rem;
    }

    .usa250-landing-hero-buttons {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 28px;
    }

    .usa250-landing-hero-primary-button,
    .usa250-landing-hero-secondary-button,
    .usa250-landing-event-button,
    .usa250-landing-cta-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 46px;
      padding: 12px 22px;
      border: 1px solid var(--usa250-accent);
      background: transparent;
      color: var(--usa250-accent);
      text-decoration: none;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-size: 0.875rem;
      font-weight: 700;
      transition: background-color 0.2s ease, color 0.2s ease;
    }

    .usa250-landing-hero-primary-button,
    .usa250-landing-event-button,
    .usa250-landing-cta-button {
      background: var(--usa250-accent);
      color: #0b1731;
    }

      .usa250-landing-cta-button {
      margin-top: 28px;
    }

    .usa250-landing-hero-primary-button:hover,
    .usa250-landing-hero-secondary-button:hover,
    .usa250-landing-event-button:hover,
    .usa250-landing-cta-button:hover {
      background: var(--usa250-accent);
      color: #0b1731;
    }

    .usa250-landing-hero-inline-image {
      margin-top: 28px;
      max-width: 100%;
    }

    .usa250-landing-hero-inline-image img {
      display: block;
      width: 100%;
      height: auto;
      object-fit: contain;
    }

    .usa250-landing-intro-section {
      display: flex;
      flex-wrap: wrap;
      background: linear-gradient(90deg, #f3efe5 0%, #f6f6f6 100%);
      color: #122b53;
    }

    .usa250-landing-intro-media {
      flex: 1 1 57%;
      max-width: 57%;
      position: relative;
      background: #d9d9d9;
      overflow: hidden;
    }

    .usa250-landing-intro-media img,
    .usa250-landing-intro-watch img,
    .usa250-landing-feature-media img,
    .usa250-landing-story-media img,
    .usa250-landing-timeline-image img,
    .usa250-landing-heritage-photo img,
    .usa250-landing-cta-media img,
    .usa250-landing-scene-card img,
    .usa250-landing-detail-asset img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .usa250-landing-intro-placeholder,
    .usa250-landing-feature-placeholder,
    .usa250-landing-story-placeholder,
    .usa250-landing-heritage-placeholder,
    .usa250-landing-scene-placeholder {
      min-height: 180px;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
      text-align: center;
      color: var(--usa250-muted);
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02));
    }

    .usa250-landing-intro-watch {
      position: absolute;
      width: min(34%, 220px);
      right: 8%;
      bottom: 0;
      aspect-ratio: 0.7;
    }

    .usa250-landing-intro-copy {
      flex: 1 1 43%;
      max-width: 43%;
      padding: 34px 30px;
      display: flex;
      align-items: center;
    }

    .usa250-landing-intro-title {
      margin: 0;
      color: #173f72;
      font-size: clamp(1.8rem, 3vw, 3rem);
      line-height: 1.03;
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }

    .usa250-landing-intro-text,
    .usa250-landing-intro-text p {
      color: #213c68;
    }

    .usa250-landing-features-section {
      background: linear-gradient(180deg, #07142d 0%, #08152f 100%);
      padding: 28px 0 0;
    }

    .usa250-landing-features-title {
      margin: 0;
      text-align: center;
      padding: 0 18px 22px;
      color: var(--usa250-accent);
      font-size: clamp(1.2rem, 2vw, 1.8rem);
      line-height: 1.1;
      text-transform: uppercase;
    }

    .usa250-landing-features-grid {
      display: flex;
      flex-wrap: wrap;
    }

    .usa250-landing-feature-card,
    .usa250-landing-heritage-card,
    .usa250-landing-detail-card {
      padding: 24px 18px;
      border-right: 1px solid var(--usa250-border);
    }

    .usa250-landing-feature-card {
      flex: 0 0 25%;
      max-width: 25%;
      display: flex;
      align-items: flex-start;
      gap: 14px;
    }

    .usa250-landing-feature-copy {
      flex: 1 1 auto;
      display: flex;
      flex-direction: column;
    }

    .usa250-landing-feature-media {
      width: 60px;
      min-width: 60px;
      height: 60px;
      overflow: hidden;
      border-radius: 50%;
      background: #0d1b38;
      flex-shrink: 0;
    }

    .usa250-landing-feature-card:last-child,
    .usa250-landing-heritage-card:last-child,
    .usa250-landing-detail-card:last-child {
      border-right: 0;
    }

    .usa250-landing-feature-icon,
    .usa250-landing-heritage-icon {
      width: 42px;
      height: 42px;
      border-radius: 50%;
      border: 1px solid rgba(222, 188, 103, 0.75);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--usa250-accent);
      font-size: 0.78rem;
      letter-spacing: 0.08em;
      flex-shrink: 0;
    }

    .usa250-landing-feature-title,
    .usa250-landing-heritage-title,
    .usa250-landing-detail-title {
      margin: 0;
      color: var(--usa250-accent);
      font-size: 0.95rem;
      line-height: 1.45;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .usa250-landing-feature-text,
    .usa250-landing-heritage-text,
    .usa250-landing-detail-text {
      margin: 10px 0 0;
      color: var(--usa250-muted);
      font-size: 0.86rem;
      line-height: 1.6;
    }

    .usa250-landing-feature-text p {
      margin: 0;
    }

    .usa250-landing-feature-text p + p {
      margin-top: 4px;
    }

    .usa250-landing-story-section {
      display: flex;
      flex-direction: column;
      background: linear-gradient(180deg, #081329 0%, #092241 100%);
      background-position: center;
      background-repeat: no-repeat;
      background-size: cover;
    }

    .usa250-landing-story-copy {
      padding: 36px 28px;
      min-height: 320px;
      display: flex;
      align-items: center;
    }

    .usa250-landing-story-title {
      margin: 0;
      color: var(--usa250-text);
      font-size: clamp(1.6rem, 2.8vw, 2.9rem);
      line-height: 1.04;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .usa250-landing-story-kicker {
      margin: 18px 0 0;
      color: var(--usa250-accent);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      font-weight: 700;
    }

    .usa250-landing-values-section {
      display: flex;
      flex-wrap: wrap;
      background: linear-gradient(90deg, #f5f1e7 0%, #0b2349 0%);
    }

    .usa250-landing-timeline-panel {
      flex: 1 1 54.5%;
      max-width: 54.5%;
      color: #3c2b13;
    }

    .usa250-landing-timeline-title {
      margin: 0;
      color: #3d2b18;
      font-size: clamp(1.4rem, 2vw, 2rem);
      line-height: 1.15;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .usa250-landing-timeline-image {
    }

    .usa250-landing-timeline-line {
      display: flex;
      gap: 10px;
      align-items: center;
      margin-top: 14px;
      color: #722b1d;
      font-weight: 700;
    }

    .usa250-landing-timeline-bar {
      flex: 1 1 auto;
      height: 2px;
      background: linear-gradient(90deg, #cfa74e 0%, #234e88 100%);
    }

    .usa250-landing-values-panel {
      background: linear-gradient(180deg, #082149 0%, #091936 100%);
      color: var(--usa250-text);
      display: flex;
      flex: 1 1 45.5%;
      max-width: 45.5%;
    }

    .usa250-landing-values-list {
      flex: 1 1 52%;
      padding: 26px 24px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 12px;
    }

    .usa250-landing-value-item {
      display: flex;
      align-items: center;
      gap: 12px;
      color: var(--usa250-accent);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-size: 1rem;
    }

    .usa250-landing-value-icon {
      width: 40px;
      min-width: 40px;
      height: 40px;
      overflow: hidden;
      border-radius: 50%;
      flex: 0 0 auto;
    }

    .usa250-landing-value-icon img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .usa250-landing-value-mark {
      width: 18px;
      height: 18px;
      border: 1px solid currentColor;
      border-radius: 50%;
      flex: 0 0 auto;
    }

    .usa250-landing-values-copy {
      flex: 1 1 48%;
      padding: 26px 20px 26px 0;
      align-self: center;
      color: var(--usa250-text);
      line-height: 1.7;
    }

    .usa250-landing-heritage-section {
      display: flex;
      flex-wrap: wrap;
      background: linear-gradient(180deg, #06172f 0%, #0b1d39 100%);
    }

    .usa250-landing-heritage-copy {
      flex: 1;
    }

    .usa250-landing-heritage-copy-image {
      overflow: hidden;
    }

    .usa250-landing-heritage-copy-image img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .usa250-landing-heritage-heading,
    .usa250-landing-detail-heading,
    .usa250-landing-scenes-heading {
      margin: 0;
      text-align: center;
      color: var(--usa250-text);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-size: clamp(1.35rem, 2vw, 1.8rem);
    }

    .usa250-landing-detail-heading,
    .usa250-landing-scenes-heading {
      padding: 18px 16px;
    }

    .usa250-landing-heritage-grid {
      display: flex;
      flex-wrap: wrap;
      margin-top: 18px;
      border-top: 1px solid var(--usa250-border);
    }

    .usa250-landing-heritage-photo {
      flex: 1 1 30%;
      max-width: 30%;
      {% comment %} min-height: 240px; {% endcomment %}
      background: #d4d4d4;
    }

    .usa250-landing-detail-section {
      display: flex;
      flex-wrap: wrap;
      background: linear-gradient(180deg, #071a34 0%, #0c2246 100%);
    }

    .usa250-landing-detail-main {
      flex: 1 1 72.5%;
      max-width: 72.5%;
      border-right: 1px solid var(--usa250-border);
    }

    .usa250-landing-detail-grid {
      display: flex;
      flex-wrap: wrap;
      border-top: 1px solid var(--usa250-border);
    }

    .usa250-landing-detail-image {
    }

    .usa250-landing-detail-image img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .usa250-landing-detail-asset {
      width: 72px;
      height: 72px;
      margin: 0 auto 14px;
      border-radius: 50%;
      overflow: hidden;
      background: rgba(255, 255, 255, 0.05);
    }

    .usa250-landing-detail-asset-placeholder {
      min-height: 72px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--usa250-muted);
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02));
    }

    .usa250-landing-detail-title,
    .usa250-landing-detail-text {
      text-align: center;
    }

    .usa250-landing-event-panel {
      flex: 1 1 27.5%;
      max-width: 27.5%;
      padding: 24px 22px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      background: linear-gradient(180deg, #0b1e3f 0%, #0b1630 100%);
    }

    .usa250-landing-event-title {
      margin: 0;
      color: var(--usa250-accent);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      line-height: 1.2;
      font-size: 1.65rem;
    }

    .usa250-landing-event-list {
      margin: 18px 0 0;
      padding: 0;
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 8px;
      color: var(--usa250-text);
      font-size: 0.9rem;
    }

    .usa250-landing-countdown {
      padding: 18px;
      border: 1px solid var(--usa250-border);
      background: rgba(255, 255, 255, 0.03);
      border-radius: 8px;
    }

    .usa250-landing-countdown-title {
      color: #ffffff;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      font-size: 0.82rem;
      margin: 0 0 12px;
      text-align: center;
    }

    .usa250-landing-countdown-grid {
      display: flex;
      flex-wrap: nowrap;
      gap: 8px;
    }

    .usa250-landing-countdown-days-box,
    .usa250-landing-countdown-hours-box,
    .usa250-landing-countdown-minutes-box,
    .usa250-landing-countdown-seconds-box {
      flex: 1 1 0;
      min-width: 0;
      padding: 10px 6px;
      text-align: center;
      background: transparent;
    }

    .usa250-landing-countdown-days-value,
    .usa250-landing-countdown-hours-value,
    .usa250-landing-countdown-minutes-value,
    .usa250-landing-countdown-seconds-value {
      display: block;
      color: var(--usa250-accent);
      font-size: 1.5rem;
      font-weight: 700;
      line-height: 1;
       border: 1px solid var(--usa250-border);
       padding: 14px 0;
       border-radius: 8px;
    }

    .usa250-landing-countdown-days-label,
    .usa250-landing-countdown-hours-label,
    .usa250-landing-countdown-minutes-label,
    .usa250-landing-countdown-seconds-label {
      display: block;
      margin-top: 6px;
      color: var(--usa250-muted);
      font-size: 0.68rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .usa250-landing-event-button {
      margin-top: 18px;
      width: 70%;
      align-self: center;
    }

    .usa250-landing-scenes-section {
      background: linear-gradient(180deg, #071a35 0%, #0d2144 100%);
    }

    .usa250-landing-scenes-grid {

    }

    .usa250-landing-scene-card {
      min-height: 180px;
      position: relative;
      border-right: 1px solid var(--usa250-border);
      overflow: hidden;
    }

    .usa250-landing-scene-card:last-child {
      border-right: 0;
    }

    .usa250-landing-scene-caption {
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      padding: 12px 10px;
      background: linear-gradient(180deg, rgba(5, 18, 39, 0) 0%, rgba(5, 18, 39, 0.92) 100%);
      color: var(--usa250-text);
      text-transform: uppercase;
      text-align: center;
      font-size: 0.78rem;
      letter-spacing: 0.08em;
    }

    .usa250-landing-compare-section {
      background: #f8f8f6;
      color: #223758;
    }

    .usa250-landing-testimonial-panel,
    .usa250-landing-compare-table-panel {
      padding: 24px 22px;
    }

    .usa250-landing-testimonial-panel {
      border-right: 1px solid #d9d9d9;
    }

    .usa250-landing-testimonial-heading,
    .usa250-landing-compare-heading {
      margin: 0 0 14px;
      color: #173f72;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-size: 1.15rem;
      text-align: center;
    }

    .usa250-landing-testimonial-stars {
      color: var(--usa250-accent);
      font-size: 0.85rem;
      letter-spacing: 0.12em;
      margin-bottom: 12px;
    }

    .usa250-landing-testimonial-quote {
      margin: 0;
      line-height: 1.7;
      font-size: 0.98rem;
      color: #223758;
    }

    .usa250-landing-testimonial-author {
      margin-top: 14px;
      color: #6a7384;
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .usa250-landing-compare-table {
      width: 100%;
      border-collapse: collapse;
    }

    .usa250-landing-compare-table th,
    .usa250-landing-compare-table td {
      padding: 10px 8px;
      border-bottom: 1px solid #d9d9d9;
      text-align: center;
      font-size: 0.88rem;
    }

    .usa250-landing-compare-table th:first-child,
    .usa250-landing-compare-table td:first-child {
      text-align: left;
    }

    .usa250-landing-cta-section {
      position: relative;
      min-height: 250px;
      overflow: hidden;
      background: linear-gradient(180deg, #081933 0%, #0b2147 100%);
    }

    .usa250-landing-cta-media,
    .usa250-landing-cta-media img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
    }

    .usa250-landing-cta-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, rgba(5, 17, 38, 0.82) 0%, rgba(5, 17, 38, 0.52) 100%);
    }

    .usa250-landing-cta-content {
      position: relative;
      z-index: 1;
      min-height: 250px;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 32px 20px;
    }

    .usa250-landing-cta-title {
      margin: 0;
      color: var(--usa250-text);
      font-size: clamp(1.8rem, 3vw, 2.8rem);
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

